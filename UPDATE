local function connectOldChat()
    for _, p in ipairs(game.Players:GetPlayers()) do
        if isAdminName(p.Name) then
            p.Chatted:Connect(function(msg) handleCommand(p.Name, msg) end)
        end
    end
    game.Players.PlayerAdded:Connect(function(p)
        if isAdminName(p.Name) then
            p.Chatted:Connect(function(msg) handleCommand(p.Name, msg) end)
        end
    end)
end

local function connectNewChat()
    local tcs = game:GetService("TextChatService")
    if tcs and tcs.MessageReceived then
        tcs.MessageReceived:Connect(function(msg)
            if msg and msg.TextSource then
                local senderName = msg.TextSource.Name
                handleCommand(senderName, msg.Text or "")
            end
        end)
    end
end

