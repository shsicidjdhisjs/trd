local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

local hideEnabled = true

-- =========================
-- FRIEND CHECK
-- =========================
local function isFriend(player)
	return LocalPlayer:IsFriendsWith(player.UserId)
end

-- =========================
-- HIDE / SHOW
-- =========================
local function hideCharacter(character)
	for _, obj in pairs(character:GetDescendants()) do
		if obj:IsA("BasePart") or obj:IsA("Decal") then
			obj.Transparency = 1
		elseif obj:IsA("BillboardGui") then
			obj.Enabled = false
		end
	end
end

local function showCharacter(character)
	for _, obj in pairs(character:GetDescendants()) do
		if obj:IsA("BasePart") or obj:IsA("Decal") then
			if obj.Name == "HumanoidRootPart" then
				obj.Transparency = 1
			else
				obj.Transparency = 0
			end
		elseif obj:IsA("BillboardGui") then
			obj.Enabled = true
		end
	end
end

-- =========================
-- UPDATE LOGIC
-- =========================
local function updatePlayer(player)
	if player == LocalPlayer then return end

	local function apply(character)
		if hideEnabled and not isFriend(player) then
			hideCharacter(character)
		else
			showCharacter(character)
		end
	end

	if player.Character then
		apply(player.Character)
	end

	player.CharacterAdded:Connect(apply)
end

local function updateAll()
	for _, player in pairs(Players:GetPlayers()) do
		updatePlayer(player)
	end
end

-- =========================
-- DRAG BUTTON
-- =========================
local function createToggle()
	local playerGui = LocalPlayer:WaitForChild("PlayerGui")

	-- Remove old GUI (prevents duplicates after respawn)
	local old = playerGui:FindFirstChild("HidePlayersGui")
	if old then old:Destroy() end

	local gui = Instance.new("ScreenGui")
	gui.Name = "HidePlayersGui"
	gui.ResetOnSpawn = false -- 🔥 THIS is key
	gui.Parent = playerGui

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0, 140, 0, 50)
	button.Position = UDim2.new(0.8, 0, 0.8, 0)
	button.Text = hideEnabled and "Hide: ON" or "Hide: OFF"
	button.BackgroundColor3 = Color3.fromRGB(40,40,40)
	button.TextColor3 = Color3.fromRGB(255,255,255)
	button.Parent = gui

	-- Toggle
	button.MouseButton1Click:Connect(function()
		hideEnabled = not hideEnabled
		button.Text = hideEnabled and "Hide: ON" or "Hide: OFF"
		updateAll()
	end)

	-- Drag system
	local dragging = false
	local dragStart
	local startPos

	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = button.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement 
		or input.UserInputType == Enum.UserInputType.Touch) then
			
			local delta = input.Position - dragStart
			
			button.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

-- =========================
-- SETUP
-- =========================
createToggle()
updateAll()

Players.PlayerAdded:Connect(updatePlayer)

-- When YOU respawn
LocalPlayer.CharacterAdded:Connect(function(char)
	showCharacter(char)
	task.wait(0.2)
	updateAll() -- reapply hiding after respawn
end)
